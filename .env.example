# CAPTCHA Providers API Keys
TWOCAPTCHA_API_KEY=your_2captcha_api_key_here
SOLVECAPTCHA_API_KEY=your_solvecaptcha_api_key_here
CAPSOLVER_API_KEY=your_capsolver_api_key_here

# Scraper Settings
# Available providers: 2captcha, solvecaptcha, capsolver
CAPTCHA_PROVIDER=2captcha
HEADLESS=true

# Proxy Settings (Optional)
# PROXY_SERVER: The network address of the proxy server (e.g., http://myproxy:3128 or socks5://myproxy:8080)
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
# PROXY_BYPASS: Comma-separated domains to bypass proxy (e.g., .com,chromium.org)
PROXY_BYPASS=
